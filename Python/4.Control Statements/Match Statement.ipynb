   "source": [
    "#### Match-Case :-\n",
    "\n",
    "Alternative to switch-case.\n",
    "\n",
    "Python 3.10+"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "7b4b9a75-a3ce-4ca4-8f83-c0707cf9d869",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Tuesday\n"
     ]
    }
   ],
   "source": [
    "day = 2\n",
    "match day:\n",
    "    case 1:\n",
    "        print('Monday')\n",
    "    case 2:\n",
    "        print('Tuesday')\n",
    "    case 3:\n",
    "        print('Wednesday')\n",
    "    case _ :\n",
    "        print('Invalid')"
   ]
  },
